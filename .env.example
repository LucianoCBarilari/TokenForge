# TokenForge — Environment Variables Template
# Copy this file to .env and fill in real values.
# .env is gitignored. This file is safe to commit.

# ─── JWT ───────────────────────────────────────────────
JwtSettings__SecretKey=
JwtSettings__Issuer=https://auth.yourdomain.com
JwtSettings__Audience=https://api.yourdomain.com
JwtSettings__AccessTokenMinutes=30

# ─── Refresh Token ─────────────────────────────────────
RefreshTokenSecurity__HashKey=

# ─── Auth Cookie ───────────────────────────────────────
AuthCookie__AccessTokenMinutesFallback=30
AuthCookie__RefreshTokenDays=30
AuthCookie__Secure=true
AuthCookie__HttpOnly=true
AuthCookie__SameSite=Strict

# ─── Database ──────────────────────────────────────────
MSSQL_SA_PASSWORD=
ConnectionStrings__JWT_Security=Server=db;Database=TokenForge;User Id=sa;Password=;TrustServerCertificate=True;

# ─── Bootstrap Admin (disable after first login) ───────
BootstrapAdmin__Enabled=false
BootstrapAdmin__UserAccount=admin
BootstrapAdmin__Email=admin@yourdomain.com
BootstrapAdmin__Password=
BootstrapAdmin__RoleName=Admin
BootstrapAdmin__ResetPasswordOnStartup=false

# ─── CORS ──────────────────────────────────────────────
Cors__AllowedOrigins__0=https://admin.yourdomain.com

# ─── Forwarded Headers ─────────────────────────────────
ForwardedHeaders__ForwardLimit=1
ForwardedHeaders__KnownProxies__0=127.0.0.1

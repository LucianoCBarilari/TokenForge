{
  "JwtSettings": {
    "SecretKey": "",
    "Issuer": "",
    "Audience": "",
    "AccessTokenMinutes": 30
  },
  "AuthCookie": {
    "AccessTokenMinutesFallback": 30,
    "RefreshTokenDays": 30,
    "Secure": true,
    "HttpOnly": true,
    "SameSite": "Strict"
  },
  "RefreshTokenSecurity": {
    "HashKey": ""
  },
  "BootstrapAdmin": {
    "Enabled": false,
    "UserAccount": "",
    "Email": "",
    "Password": "",
    "RoleName": "Admin",
    "ResetPasswordOnStartup": false
  },
  "ConnectionStrings": {
    "JWT_Security": ""
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "ForwardedHeaders": {
    "ForwardLimit": 1,
    "KnownProxies": []
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Warning",
        "System": "Warning",
        "Web": "Information",
        "Application": "Information",
        "Infrastructure": "Information",
        "Domain": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/tokenforge-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}

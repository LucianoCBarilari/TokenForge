{
  "JwtSettings": {
    "SecretKey": "CHANGE_ME",
    "Issuer": "TokenForge",
    "Audience": "TokenForge",
    "AccessTokenMinutes": 30
  },
  "AuthCookie": {
    "AccessTokenMinutesFallback": 30,
    "RefreshTokenDays": 30,
    "Secure": true,
    "HttpOnly": true,
    "SameSite": "Strict"
  },
  "RefreshTokenSecurity": {
    "HashKey": "CHANGE_ME"
  },
  "BootstrapAdmin": {
    "Enabled": false,
    "UserAccount": "admin",
    "Email": "admin@tokenforge.local",
    "Password": "CHANGE_ME",
    "RoleName": "Admin",
    "ResetPasswordOnStartup": false
  },
  "ConnectionStrings": {
    "JWT_Security": "Server=localhost;Database=TokenForge;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "ForwardedHeaders": {
    "ForwardLimit": 1,
    "KnownProxies": []
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Warning",
        "System": "Warning",
        "Web": "Debug",
        "Application": "Debug",
        "Infrastructure": "Debug",
        "Domain": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
